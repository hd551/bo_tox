    bc.CornerRadius = UDim.new(0, 10)
    bc.Parent = bigBtn

    bigBtn.MouseButton1Click:Connect(function()
        applyChest(chestVal + 0.5)
        -- تحديث موقع الشريط
        local newPos = (chestVal - minVal) / (maxVal - minVal)
        sliderBtn.Position = UDim2.new(0, newPos * (sliderBar.AbsoluteSize.X - sliderBtn.AbsoluteSize.X), 0, -6)
        if valLabel then valLabel.Text = string.format("%.1f", chestVal) end
        if textBox then textBox.Text = string.format("%.1f", chestVal) end
    end)

    -- =========================================
    -- 4. شريط التمرير (Slider)
    -- =========================================
    local sliderContainer = Instance.new(dec("\x46\x1C\x0B\x0B\x1F\x18\x17\x1C\x14\x0F\x18")) -- Frame
    sliderContainer.Size = UDim2.new(0, 260, 0, 30)
    sliderContainer.Position = UDim2.new(0.5, -130, 0, 100)
    sliderContainer.BackgroundTransparency = 1
    sliderContainer.Parent = mainFrame

    local sliderBar = Instance.new(dec("\x46\x1C\x0B\x0B\x1F\x18\x17\x1C\x14\x0F\x18")) -- Frame
