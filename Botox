    txtBoxContainer.Position = UDim2.new(0.5, -60, 0, 155)
    txtBoxContainer.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    txtBoxContainer.BackgroundTransparency = 0.3
    txtBoxContainer.Parent = mainFrame
    local tbc = Instance.new(dec("\x56\x1E\x17\x0E\x0B\x17"))
