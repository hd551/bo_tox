    fillBar.Size = UDim2.new(0, 0, 1, 0)
    fillBar.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
    fillBar.BackgroundTransparency = 0.2
    fillBar.Parent = sliderBar
    local fc = Instance.new(dec("\x56\x1E\x17\x0E\x0B\x17"))
    fc.CornerRadius = UDim.new(1, 0)
    fc.Parent = fillBar

    -- زر الشريط (القابض)
    local sliderBtn = Instance.new(dec("\x46\x1C\x0B\x0B\x1F\x18\x17\x1C\x14\x0F\x18")) -- TextButton
    sliderBtn.Size = UDim2.new(0, 22, 0, 22)
