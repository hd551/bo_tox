    sc2.CornerRadius = UDim.new(1, 0)
    sc2.Parent = sliderBtn
    local stroke3 = Instance.new(dec("\x56\x15\x13\x17\x17\x1C\x14\x0F\x18"))
    stroke3.Color = Color3.fromRGB(88, 101, 242)
    stroke3.Thickness = 2
    stroke3.Parent = sliderBtn

    -- قيمة الشريط النصية
    local valLabel = Instance.new(dec("\x46\x1C\x0B\x0B\x1F\x18\x17\x1C\x14\x0F\x18")) -- TextLabel
    valLabel.Size = UDim2.new(0, 40, 0, 20)
    valLabel.Position = UDim2.new(1, 10, 0.5, -10)
    valLabel.BackgroundTransparency = 1
    valLabel.Text = "1.0"
    valLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
    valLabel.TextSize = 14
    valLabel.Font = Enum.Font.GothamBold
    valLabel.Parent = sliderContainer

    -- [[ منطق سحب الشريط ]]
    local dragging = false
    local dragInput
    local function updateSlider(input)
        local barPos = sliderBar.AbsolutePosition.X
        local barWidth = sliderBar.AbsoluteSize.X
        local mouseX = input.Position.X
        local offset = math.clamp(mouseX - barPos, 0, barWidth)
        local percent = offset / barWidth
        local newVal = minVal + (maxVal - minVal) * percent
        applyChest(newVal)
        sliderBtn.Position = UDim2.new(0, offset - 11, 0, -6)
        fillBar.Size = UDim2.new(percent, 0, 1, 0)
        if textBox then textBox.Text = string.format("%.1f", chestVal) end
        if valLabel then valLabel.Text = string.format("%.1f", chestVal) end
    end

    sliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)

    sliderBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    uis.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)

    -- =========================================
    -- 5. مربع الكتابة (TextBox)
    -- =========================================
    local txtBoxContainer = Instance.new(dec("\x46\x1C\x0B\x0B\x1F\x18\x17\x1C\x14\x0F\x18")) -- Frame
